local function isValidTarget(char)
    return char and char.Parent and char:FindFirstChild("HumanoidRootPart") and 
           char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0
end

local function updatePlatform(position)
    if platform then
        platform.Position = position - Vector3.new(0, 3, 0)
    else
        platform = Instance.new("Part")
        platform.Size = Vector3.new(5, 1, 5)
        platform.Anchored = true
        platform.CanCollide = false
        platform.Transparency = 1
        platform.Position = position - Vector3.new(0, 3, 0)
        platform.Parent = workspace
    end
end

local function getOrUpdateTarget()
    if not (character and character.Parent) then return nil end
    
    if currentTarget and isValidTarget(currentTarget.Character) then
        return currentTarget
    end
    
    currentTarget = nil
    local closestDist = 30
    
    for _, otherPlayer in ipairs(game.Players:GetPlayers()) do
        if otherPlayer ~= player and isValidTarget(otherPlayer.Character) then
            local dist = (humanoidRootPart.Position - otherPlayer.Character.HumanoidRootPart.Position).Magnitude
            if dist < closestDist then
                closestDist = dist
                currentTarget = otherPlayer
            end
        end
    end
    
    return currentTarget
end

local function orbitUpdate()
    if not isActive or not (character and character.Parent) then
        if platform then platform:Destroy() end
        return 
    end
    
    local target = getOrUpdateTarget()
    if not target then return end
    
    local targetPos = target.Character.HumanoidRootPart.Position
    local speedRadians = math.rad(orbitSettings.Speed)
    currentAngle = (currentAngle + speedRadians) % (2 * math.pi)
    
    local orbitPos = targetPos + Vector3.new(
        math.cos(currentAngle) * orbitSettings.Radius,
        orbitSettings.Height,
        math.sin(currentAngle) * orbitSettings.Radius
    )
    
    humanoidRootPart.CFrame = CFrame.new(orbitPos, targetPos)
    updatePlatform(orbitPos)
end

local function startOrbit()
    if connections.heartbeat then connections.heartbeat:Disconnect() end
    connections.heartbeat = game:GetService("RunService").Heartbeat:Connect(orbitUpdate)
end

local function stopOrbit()
    if connections.heartbeat then connections.heartbeat:Disconnect() end
    if platform then platform:Destroy() end
    currentTarget = nil
end

