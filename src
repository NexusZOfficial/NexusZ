local function resetAndRespawn()
    local success = false
    local remoteInterface = rs:FindFirstChild("remoteInterface")
    if not remoteInterface then return false end
    
    local characterFolder = remoteInterface:FindFirstChild("character")
    if not characterFolder then return false end
    
    local resetRemote = characterFolder:FindFirstChild("reset")
    if resetRemote then 
        resetRemote:InvokeServer()
        task.wait(0.1)
    end
    
    local respawnRemote = characterFolder:FindFirstChild("respawn")
    if respawnRemote then
        respawnRemote:InvokeServer(unpack(respawnArgs))
        task.wait(0.3)
        success = true
    end
    return success
end

local function teleportToPlayer()
    if not targetPlayer or not targetPlayer.Character then return false end
    
    local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
    local humanoidRootPart = character:WaitForChild("HumanoidRootPart", 5)
    
    if humanoidRootPart and targetPlayer.Character then
        humanoidRootPart.CFrame = targetPlayer.Character.HumanoidRootPart.CFrame
        return true
    end
    return false
end

local function startLoopTeleport()
    if teleportConnection then teleportConnection:Disconnect() end
    
    teleportConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if teleporting and targetPlayer and targetPlayer.Character then
            local char = localPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.CFrame = targetPlayer.Character.HumanoidRootPart.CFrame
            end
        else
            if teleportConnection then
                teleportConnection:Disconnect()
                teleportConnection = nil
            end
        end
    end)
end

