local function attemptRespawn()
    if respawnDebounce then return end
    respawnDebounce = true
    
    local rs = game:GetService("ReplicatedStorage")
    if not rs then 
        respawnDebounce = false
        return 
    end
    
    local remoteInterface = rs:FindFirstChild("remoteInterface")
    if not remoteInterface then 
        respawnDebounce = false
        return 
    end
    
    local characterFolder = remoteInterface:FindFirstChild("character")
    if not characterFolder then 
        respawnDebounce = false
        return 
    end
    
    local resetRemote = characterFolder:FindFirstChild("reset")
    if resetRemote then
        resetRemote:InvokeServer()
    end
    
    local respawnRemote = characterFolder:FindFirstChild("respawn")
    if respawnRemote then
        respawnRemote:InvokeServer(unpack(respawnArgs))
    end
    
    respawnDebounce = false
end

local function teleport(cframe)
    isTeleporting = true
    local player = game.Players.LocalPlayer
    local maxWaitTime = 0.5
    local startTime = tick()
    
    while not player.Character and tick() - startTime < maxWaitTime do
        task.wait(0.2)
    end
    
    if not player.Character then 
        isTeleporting = false
        return 
    end
    
    local humanoidRootPart = player.Character:FindFirstChild("HumanoidRootPart")
    local waitTime = 0
    
    while not humanoidRootPart and waitTime < maxWaitTime do
        task.wait(0.2)
        waitTime = waitTime + 0.01
        humanoidRootPart = player.Character:FindFirstChild("HumanoidRootPart")
    end
    
    if humanoidRootPart then
        humanoidRootPart.CFrame = cframe
    end
    isTeleporting = false
end

