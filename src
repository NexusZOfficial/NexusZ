    if not shouldAutoRespawn or isTeleporting then return end
    
    local player = game.Players.LocalPlayer
    
    if not player.Character or not workspace:FindFirstChild(player.Name) then
        if lastDeathPosition then
            task.wait(0.00014)
            attemptRespawn()
            destroyAvatarGUI()
            task.wait(teleportDelay)
            teleport(CFrame.new(lastDeathPosition))
